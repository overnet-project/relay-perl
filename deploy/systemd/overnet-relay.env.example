OVERNET_RELAY_HOST=127.0.0.1
OVERNET_RELAY_PORT=7447
OVERNET_RELAY_NAME=Overnet Relay
OVERNET_RELAY_DESCRIPTION=Public Overnet relay
OVERNET_RELAY_SOFTWARE=https://example.invalid/overnet-relay
OVERNET_RELAY_VERSION=0.1.0
OVERNET_RELAY_PROFILE=volunteer-basic
OVERNET_RELAY_STORE_FILE=/var/lib/overnet/relay/store.json
OVERNET_RELAY_LOG_FILE=/var/log/overnet/relay.log
OVERNET_RELAY_HEALTH_FILE=/run/overnet/relay-health.json
OVERNET_RELAY_MAX_CONNECTIONS_PER_IP=64
OVERNET_RELAY_EVENT_RATE_LIMIT=60/60
OVERNET_RELAY_SERVICE_POLICY_PUBLISH=open
OVERNET_RELAY_SERVICE_POLICY_QUERY=open
OVERNET_RELAY_SERVICE_POLICY_SUBSCRIBE=open
OVERNET_RELAY_SERVICE_POLICY_SYNC=open
OVERNET_RELAY_SERVICE_POLICY_OBJECT_READ=open
